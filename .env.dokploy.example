# Copy to .env.dokploy before deploying:
# cp .env.dokploy.example .env.dokploy

# --- Required ---
# Public domain for Convex backend (sync endpoint on 3210 and /http proxy on 3211).
DOMAIN=convex.example.com

# Public domain for the TanStack Start app.
APP_DOMAIN=issues.example.com

# Must match your public app origin exactly (no trailing slash).
SITE_URL=https://issues.example.com

# Strong secret used by Convex backend instance.
INSTANCE_SECRET=replace-with-strong-random-secret

# Optional: Convex self-hosted admin key used to deploy functions from the web container.
# You can leave this unset and use the README one-command deploy flow,
# which generates a key from the running backend automatically.
# CONVEX_SELF_HOSTED_ADMIN_KEY=

# Better Auth secret used by Convex Better Auth component.
BETTER_AUTH_SECRET=replace-with-strong-random-secret

# --- Optional ---
INSTANCE_NAME=convex-prod
DOKPLOY_NETWORK=dokploy-network
CONVEX_BACKEND_TAG=latest
CONVEX_RUST_LOG=info

# Optional SQL database for Convex (otherwise SQLite volume is used):
# DATABASE_URL=
# POSTGRES_URL=
# MYSQL_URL=

# Optional dashboard exposure through Traefik.
# If disabled, dashboard stays internal to Docker network.
EXPOSE_DASHBOARD=false
CONVEX_DASHBOARD_DOMAIN=convex-dashboard.example.com
