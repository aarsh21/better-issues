# ============================================================================
# Better Issues — Environment Variables
# ============================================================================
# Copy to `.env` for Docker or `.env.local` for local dev:
#
#   cp .env.example .env        # Docker
#   cp .env.example .env.local  # local dev (vite)
# ============================================================================

# --- Public browser variables ------------------------------------------------

# Convex realtime / sync endpoint (WebSocket).
PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Convex HTTP actions endpoint. Better Auth proxies auth requests here.
PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# Public URL of the SvelteKit app.
PUBLIC_SITE_URL=http://localhost:3000

# Controls whether the sign-up UI is shown (true | false).
PUBLIC_ALLOWED_SIGNUPS=true

# --- Better Auth (server-side) -----------------------------------------------

# Required — signing secret for sessions and tokens.
# Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# --- Convex deployment -------------------------------------------------------
# Only needed for local dev (`bunx convex dev` sets this automatically).
# In production, Convex is a hosted service — no deployment var needed at runtime.
# CONVEX_DEPLOYMENT=dev:your-project

# --- Convex environment variables --------------------------------------------
# These must be set on the Convex deployment itself (not in this file):
#
#   bunx convex env set SITE_URL          <your PUBLIC_SITE_URL>
#   bunx convex env set BETTER_AUTH_URL   <your PUBLIC_SITE_URL>
#   bunx convex env set BETTER_AUTH_SECRET <same secret as above>
#   bunx convex env set ALLOWED_SIGNUPS   true
