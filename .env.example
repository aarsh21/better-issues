# ============================================================================
# Better Issues — Environment Variables
# ============================================================================
# Copy to `.env`:  cp .env.example .env
# Or run ./start.sh which creates .env and generates secrets automatically.
# ============================================================================

# --- Public URLs -------------------------------------------------------------

# Public URL where the SvelteKit app is accessed.
PUBLIC_SITE_URL=http://localhost:3000

# Convex backend URL (browser WebSocket connects here).
# In production behind a reverse proxy, use the public domain, e.g.:
#   PUBLIC_CONVEX_URL=https://convex.yourdomain.com
PUBLIC_CONVEX_URL=http://localhost:3210

# Convex site/HTTP origin (for CORS on HTTP actions).
# Usually same host as PUBLIC_CONVEX_URL but port 3211.
# Behind a reverse proxy this may differ from the internal port.
CONVEX_SITE_ORIGIN=http://localhost:3211

# Allow signups (true | false).
PUBLIC_ALLOWED_SIGNUPS=true

# --- Secrets -----------------------------------------------------------------
# start.sh auto-generates these if left empty.

# Better Auth signing secret (openssl rand -base64 32).
BETTER_AUTH_SECRET=

# Convex instance secret (openssl rand -hex 32).
INSTANCE_SECRET=
