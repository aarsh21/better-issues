# ── better-issues: Environment Configuration ──────────────────
#
# Copy this file to .env and fill in the values.
#
# First-time setup:
#   1. Generate INSTANCE_SECRET:  openssl rand -hex 32
#   2. Generate DB_PASSWORD:      openssl rand -hex 16
#   3. Generate BETTER_AUTH_SECRET: openssl rand -hex 32
#   4. Start backend first:       docker compose up -d convex postgres
#   5. Generate admin key:        docker compose exec convex /bin/sh -c "cd convex && ./generate_admin_key.sh"
#   6. Paste the admin key below as CONVEX_ADMIN_KEY
#   7. Start everything:          docker compose up --build -d
# ───────────────────────────────────────────────────────────────

# ── Secrets (generate with: openssl rand -hex 32) ────────────
INSTANCE_SECRET=
DB_PASSWORD=
BETTER_AUTH_SECRET=

# ── Convex Admin Key ─────────────────────────────────────────
# Generated from step 5 above. Looks like:
# better-issues|<hex_string>
CONVEX_ADMIN_KEY=

# ── Public URLs ──────────────────────────────────────────────
# These MUST be the externally-accessible URLs (what the browser sees).
#
# For local testing:
#   CONVEX_CLOUD_ORIGIN=http://localhost:3210
#   CONVEX_SITE_ORIGIN=http://localhost:3211
#   SITE_URL=http://localhost:3000
#
# For Dokploy with custom domains:
#   CONVEX_CLOUD_ORIGIN=https://convex.yourdomain.com
#   CONVEX_SITE_ORIGIN=https://convex-site.yourdomain.com
#   SITE_URL=https://issues.yourdomain.com

CONVEX_CLOUD_ORIGIN=http://localhost:3210
CONVEX_SITE_ORIGIN=http://localhost:3211
SITE_URL=http://localhost:3000

# ── Ports (optional, defaults shown) ─────────────────────────
# CONVEX_PORT=3210
# CONVEX_SITE_PORT=3211
# DASHBOARD_PORT=6791
# WEB_PORT=3000

# ── Logging (optional) ──────────────────────────────────────
# RUST_LOG=info
