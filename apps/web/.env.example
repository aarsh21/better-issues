# ============================================================================
# better-issues — Web App Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local
#
# These values are for LOCAL development with `convex dev --local`.
# For production/cloud deployments, replace the URLs with your Convex
# deployment URLs.
# ============================================================================

# --- Convex CLI Variables ---------------------------------------------------
# These are used by the Convex CLI (npx convex dev) to know which deployment
# to push functions to. Generated automatically by `bun run dev:setup`.

CONVEX_DEPLOYMENT=anonymous:anonymous-better-issues
CONVEX_URL=http://127.0.0.1:3210
CONVEX_SITE_URL=http://127.0.0.1:3211

# --- Next.js Client Variables -----------------------------------------------
# These are exposed to the browser (NEXT_PUBLIC_ prefix).

# Sync protocol endpoint — used by ConvexReactClient for real-time subscriptions.
# Must point to the Convex BACKEND port (3210), NOT the site port (3211).
# Getting this wrong causes a "Client disconnected" loop.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# HTTP actions endpoint — used by Better Auth for authentication routes.
# Must point to the Convex SITE port (3211).
# Optional: falls back to NEXT_PUBLIC_CONVEX_URL if not set (only correct
# when both endpoints share the same URL, e.g. in cloud deployments).
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211
