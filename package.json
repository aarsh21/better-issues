{
  "name": "better-issues",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "better-auth": "1.4.9"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=web --filter=@better-issues/api",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev --filter=native",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=@better-issues/api",
    "db:generate": "bun --cwd packages/db ./node_modules/drizzle-kit/bin.cjs generate --config drizzle.config.ts",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:studio": "bun --cwd packages/db ./node_modules/drizzle-kit/bin.cjs studio --config drizzle.config.ts",
    "db:seed": "bun run --cwd packages/db db:seed",
    "check": "oxlint && oxfmt --write",
    "prepare": "husky"
  },
  "dependencies": {
    "@better-issues/env": "workspace:*",
    "@tanstack/react-query-devtools": "^5.90.21",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-issues/config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*": [
      "oxlint",
      "oxfmt --write"
    ]
  },
  "packageManager": "bun@1.3.7"
}
