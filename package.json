{
  "name": "better-issues",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "convex": "^1.31.2",
      "better-auth": "1.4.9",
      "@convex-dev/better-auth": "^0.10.9"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev --filter=native",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=@better-issues/backend",
    "dev:setup": "turbo run dev:setup --filter=@better-issues/backend",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "prettier --check . && eslint .",
    "prepare": "husky"
  },
  "dependencies": {
    "@better-issues/env": "workspace:*",
    "@tanstack/react-query-devtools": "^5.91.3",
    "dotenv": "^17.3.1",
    "react-grab": "^0.1.26",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-issues/config": "workspace:*",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "packageManager": "bun@1.3.7"
}
