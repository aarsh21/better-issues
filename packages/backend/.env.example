# ============================================================================
# better-issues — Convex Backend Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local
#
# These values are for LOCAL development with `convex dev --local`.
# For production/cloud deployments, replace with your Convex deployment URLs.
# ============================================================================

# --- Convex CLI Variables ---------------------------------------------------
# These are used by the Convex CLI to know which deployment to target.
# Generated automatically by `bun run dev:setup`.

CONVEX_DEPLOYMENT=anonymous:anonymous-better-issues
CONVEX_URL=http://127.0.0.1:3210
CONVEX_SITE_URL=http://127.0.0.1:3211

# --- Convex Runtime Variables -----------------------------------------------
# These are NOT set in this file. They must be set in the Convex deployment
# environment using the CLI:
#
#   bunx convex env set SITE_URL http://localhost:3001
#   bunx convex env set BETTER_AUTH_SECRET <your-secret>
#
# Generate a secret with:  openssl rand -hex 32
#
# SITE_URL            — The public URL of the web app (used by Better Auth
#                       for redirects and trusted origins).
# BETTER_AUTH_SECRET  — Secret key for Better Auth cryptographic operations.
