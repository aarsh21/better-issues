# ============================================================================
# svelte-migration — SvelteKit Environment Variables
# ============================================================================
# Copy this file to `.env.local` for local development.
#
#   cp .env.example .env.local
#
# These values assume a local Convex deployment.
# ============================================================================

# --- Convex CLI --------------------------------------------------------------
# Generated by `bunx convex dev` for the local or cloud deployment you are
# connected to.
CONVEX_DEPLOYMENT=dev:your-project

# --- Public browser variables ------------------------------------------------
# Convex realtime / sync endpoint. This must point at the Convex backend port.
PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Convex site / HTTP actions endpoint. Better Auth proxies to this URL.
PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# Public URL of the SvelteKit app during local development.
PUBLIC_SITE_URL=http://localhost:5173

# Controls whether sign-up UI should be shown in the app.
PUBLIC_ALLOWED_SIGNUPS=true

# --- Convex runtime variables ------------------------------------------------
# Set these in the Convex deployment itself, not in this file:
#
#   bunx convex env set SITE_URL http://localhost:5173
#   bunx convex env set BETTER_AUTH_URL http://localhost:5173
#   bunx convex env set BETTER_AUTH_SECRET <generated-secret>
#   bunx convex env set ALLOWED_SIGNUPS true
#
# `BETTER_AUTH_URL` should generally match `SITE_URL`. Setting both avoids
# Better Auth base URL warnings during SSR and local proxying.
#
# Generate a secret with:
#   openssl rand -base64 32
